# AI Worker

# Redis connection for Bull queue
REDIS_URL=redis://localhost:6379

# Worker settings
WORKER_PORT=3002
WORKER_HOST=0.0.0.0
NODE_ENV=development

# GPU / Model settings
MODELS_DIR=./models
PYTHON_PATH=python
CUDA_VISIBLE_DEVICES=0

# Concurrency — number of jobs processed in parallel (limited by VRAM)
WORKER_CONCURRENCY=1

# Model selection (choose models based on available VRAM)
# Options: sd-xl, sd-1.5, sdxl-turbo
VIDEO_MODEL=sd-xl
# Options: coqui-tts, bark
VOICE_MODEL=coqui-tts
# Options: musicgen-small, musicgen-medium, musicgen-large
MUSIC_MODEL=musicgen-small

# Output storage
OUTPUT_DIR=./output

# API server (for callbacks)
API_URL=http://localhost:3001

# Optional: HuggingFace token for gated models
HF_TOKEN=
