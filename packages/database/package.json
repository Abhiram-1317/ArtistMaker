{
  "name": "@genesis/database",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "prisma generate",
    "clean": "rimraf dist node_modules/.prisma",
